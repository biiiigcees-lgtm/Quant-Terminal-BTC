{
    "files.autoSave": "onFocusChange",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.fixAll.eslint": "explicit",
        "source.organizeImports": "explicit"
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/.git": true,
        "**/.DS_Store": true
    },
    "files.associations": {
        "*.js": "javascriptreact"
    }
}